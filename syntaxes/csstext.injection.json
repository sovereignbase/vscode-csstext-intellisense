{
  "scopeName": "inline.csstext.injection",
  "injectionSelector": "L:source.js, L:source.jsx, L:source.ts, L:source.tsx",
  "patterns": [
    {
      "name": "meta.css-text.template.js",
      "begin": "(\\.style\\.cssText\\s*=\\s*)(`)",
      "beginCaptures": {
        "1": {
          "name": "meta.property.object.js"
        },
        "2": {
          "name": "punctuation.definition.string.template.begin.js"
        }
      },
      "end": "((?<!\\\\)`)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.string.template.end.js"
        }
      },
      "contentName": "meta.embedded.block.css source.css",
      "patterns": [
        {
          "include": "#template-substitution"
        },
        {
          "include": "source.css"
        }
      ]
    }
  ],
  "repository": {
    "template-substitution": {
      "name": "meta.embedded.expression.js",
      "begin": "(\\$\\{)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.section.embedded.begin.js"
        }
      },
      "end": "(\\})",
      "endCaptures": {
        "1": {
          "name": "punctuation.section.embedded.end.js"
        }
      },
      "patterns": [
        {
          "include": "source.ts"
        }
      ]
    }
  }
}
