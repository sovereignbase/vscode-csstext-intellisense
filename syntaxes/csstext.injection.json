{
  "scopeName": "inline.csstext.injection",
  "injectionSelector": "L:source.js, L:source.jsx, L:source.ts, L:source.tsx",
  "patterns": [
    {
      "name": "meta.css-text.template.js",
      "begin": "(\\.style\\.cssText\\s*=\\s*)(`)",
      "beginCaptures": {
        "1": {
          "name": "meta.property.object.js"
        },
        "2": {
          "name": "punctuation.definition.string.template.begin.js"
        }
      },
      "end": "((?<!\\\\)`)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.string.template.end.js"
        }
      },
      "contentName": "meta.embedded.block.css source.css",
      "patterns": [
        {
          "include": "#declaration-list"
        }
      ]
    }
  ],
  "repository": {
    "declaration-list": {
      "patterns": [
        {
          "include": "source.css#comment-block"
        },
        {
          "include": "source.css#escapes"
        },
        {
          "include": "#template-substitution"
        },
        {
          "include": "source.css#font-features"
        },
        {
          "begin": "(?x)(?:\\G|^|(?<=;))(\\s*)((?:[-a-zA-Z_]|[^\\x00-\\x7F])(?:[-a-zA-Z0-9_]|[^\\x00-\\x7F]|\\\\(?:[0-9a-fA-F]{1,6}|.))*)\\s*(:)\\s*",
          "beginCaptures": {
            "2": {
              "name": "meta.property-name.css",
              "patterns": [
                {
                  "include": "source.css#property-names"
                }
              ]
            },
            "3": {
              "name": "punctuation.separator.key-value.css"
            }
          },
          "end": "\\s*(;)|\\s*(?=`|\\n\\s*(?:--|[-a-zA-Z]+\\s*:))",
          "endCaptures": {
            "1": {
              "name": "punctuation.terminator.rule.css"
            }
          },
          "contentName": "meta.property-value.css",
          "patterns": [
            {
              "include": "#template-substitution"
            },
            {
              "include": "source.css#property-values"
            }
          ]
        },
        {
          "begin": "(?:\\G|^|(?<=;))\\s*(?=[-a-zA-Z])",
          "end": "$|(?![-a-zA-Z])",
          "name": "meta.property-name.css",
          "patterns": [
            {
              "include": "source.css#property-names"
            }
          ]
        },
        {
          "match": ";",
          "name": "punctuation.terminator.rule.css"
        }
      ]
    },
    "template-substitution": {
      "name": "meta.embedded.expression.js",
      "begin": "(\\$\\{)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.section.embedded.begin.js"
        }
      },
      "end": "(\\})",
      "endCaptures": {
        "1": {
          "name": "punctuation.section.embedded.end.js"
        }
      },
      "patterns": [
        {
          "include": "source.ts"
        }
      ]
    }
  }
}
