{
  "name": "vscode-csstext-intellisense",
  "displayName": "cssText IntelliSense",
  "description": "CSS syntax highlighting and completions for HTMLElement.style.cssText template literals.",
  "version": "1.2.1",
  "publisher": "sovereignbase",
  "license": "Apache-2.0",
  "author": "Jori Lehtinen",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/sovereignbase/vscode-csstext-intellisense.git"
  },
  "bugs": {
    "url": "https://github.com/sovereignbase/vscode-csstext-intellisense/issues"
  },
  "homepage": "https://github.com/sovereignbase/vscode-csstext-intellisense#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "css",
    "csstext",
    "intellisense",
    "template-literals",
    "vscode-extension"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "grammars": [
      {
        "scopeName": "inline.csstext.injection",
        "path": "./syntaxes/csstext.injection.json",
        "injectTo": [
          "source.js",
          "source.jsx",
          "source.ts",
          "source.tsx"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.css": "css"
        },
        "tokenTypes": {
          "meta.embedded.block.css": "other"
        }
      }
    ]
  },
  "scripts": {
    "build": "tsc -p .",
    "format": "prettier . --write",
    "package": "vsce package",
    "test": "npm run build && node test/run.mjs && npm run package",
    "vscode:prepublish": "npm run build",
    "watch": "tsc -w -p ."
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.2.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "vscode-css-languageservice": "^6.3.10"
  }
}
